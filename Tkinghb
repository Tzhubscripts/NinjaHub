-- Função para encontrar a Área Segura (SafeZone)
local function getSafeZone()
    local names = {"SafeZone", "Safe Zone", "SpeedShop", "Safezone", "SafeArea", "WinPart", "TopPlatform"}
    for _, name in pairs(names) do
        local obj = game:GetService("Workspace"):FindFirstChild(name, true)
        if obj and (obj:IsA("BasePart") or obj:IsA("Model")) then
            return obj
        end
    end
    return nil
end

-- Auto Win Loop
spawn(function()
    while wait(0.5) do
        if _G.Settings.Main.AutoWin then
            local sz = getSafeZone()
            if sz and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = sz:IsA("Model") and sz:GetModelCFrame() or sz.CFrame
                LocalPlayer.Character.HumanoidRootPart.CFrame = targetPos + Vector3.new(0, 5, 0)
            end
        end
    end
end)

-- Função para verificar raridade do Brainrot (aprimorada)
local function checkRarity(obj)
    local selected = _G.Settings.Settings.Main.SelectedRarity;
    if selected == "All" then return true end
    
    local name = obj.Name:lower();
    -- Tenta encontrar a raridade no nome do objeto
    if name:find(selected:lower()) then return true end
    
    -- Tenta encontrar a raridade em atributos ou children (se o jogo usar)
    local rarityAttr = obj:FindFirstChild("Rarity") or obj:GetAttribute("Rarity");
    if rarityAttr and tostring(rarityAttr):lower() == selected:lower() then
        return true
    end
    
    -- Última tentativa: verificar se o nome do objeto contém qualquer parte da raridade
    for _, r in pairs(Rarities) do
        if r ~= "All" and selected == r and name:find(r:lower()) then
            return true
        end
    end
    
    return false
end

-- Auto Farm Brute Force Loop (Coleta tudo com TouchTransmitter de forma segura e com filtro de raridade)
spawn(function()
    while wait(0.05) do -- Pequeno delay para evitar anti-cheat e suavizar teleportes
        if _G.Settings.Main.AutoFarmBruteForce then
            -- Verifica a vida antes de teleportar
            if Humanoid.Health < 20 and Humanoid.Health > 0 then 
                print("T' Khub: Vida baixa! Auto Farm pausado por 3 segundos.");
                _G.Settings.Main.AutoFarmBruteForce = false; -- Desativa o toggle
                wait(3); -- Espera para recuperação
            end

            local itemsToCollect = {};
            for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
                if v:IsA("TouchTransmitter") and v.Parent and v.Parent:IsA("BasePart") then
                    -- Filtro de altura: só coleta se o item estiver acima de um certo nível (ex: 0 ou 5)
                    -- Ajuste este valor (5) se o chão do jogo for mais baixo ou mais alto
                    if v.Parent.Position.Y > 5 then 
                        -- Verifica a raridade antes de adicionar à lista de coleta
                        if checkRarity(v.Parent) then
                            table.insert(itemsToCollect, v.Parent);
                        end
                    end
                end
            end

            -- Teleporta para cada item coletável
            for _, item in pairs(itemsToCollect) do
                if _G.Settings.Main.AutoFarmBruteForce and HumanoidRootPart and item and item.Parent then
                    local targetCFrame = item.CFrame;
                    if _G.Settings.Main.GhostFarm then
                        targetCFrame = targetCFrame * CFrame.new(0, -5, 0); -- Teleporta 5 studs abaixo do item
                    end
                    HumanoidRootPart.CFrame = targetCFrame; 
                    firetouchinterest(LocalPlayer.Character.HumanoidRootPart, item, 0)
                    firetouchinterest(LocalPlayer.Character.HumanoidRootPart, item, 1)
                    wait(0.05); -- Pequeno delay entre cada coleta
                end
            end
        end
    end
end)

